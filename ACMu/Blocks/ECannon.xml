<Block>
    <Debug>true</Debug>
    <ID>2</ID>
    <Name>75mmL48HE (ACMu)</Name>
    <Mass>1.0</Mass>
    <Fallback>Cannon</Fallback>

    <ModuleMapperTypes>
        <Key displayName="Shot" key="fire" default="C" />
        <Slider displayName="Power" key="power" min="50" max="550" default="250" unclamped="false" />
        <Slider displayName="Rate Of Fire" key="rate-of-fire" min="0.10" max="1.00" default="0.37" unclamped="false" />
        <Slider displayName="Fuse Timer" key="fuse-timer" min="0.5" max="10.0" default="3.0" unclamped="false" />
        <Toggle displayName="Hold To Shoot" key="hold-to-shoot" default="true" />
        <!-- useMagazine テスト用 -->
        <Key displayName="Reload" key="reload" default="R" />
        <Toggle displayName="Auto Reload" key="auto-reload" default="false" />
        <Slider displayName="Magazine Capacity" key="magazine-capacity" min="1" max="20" default="5" unclamped="false" />
        <Slider displayName="Reload Time" key="reload-time" min="0.2" max="5.0" default="1.5" unclamped="false" />
        <!-- useThrustDelayTimer テスト用 -->
        <Slider displayName="Thrust Delay Timer" key="thrust-delay-timer" min="0.0" max="3.0" default="0.5" unclamped="false" />
    </ModuleMapperTypes>

    <Modules>
        <AdShootingProp modid="e2650bb4-7195-42a8-93c4-bdab66f5b571">

            <ShootingState>
                <Mass>0.6</Mass>
                <Drag>0.0</Drag>
                <AngularDrag>0.0</AngularDrag>
                <IgnoreGravity>False</IgnoreGravity>
                <EntityDamage>40</EntityDamage>
                <BlockDamage>10000.0</BlockDamage>
                <!-- 接着効果: true にすると着弾した弾が対象に刺さって止まる(Despawnは寿命タイムアウト任せ) -->
                <Attaches>false</Attaches>
                <CollisionTypeS>ContinuousDynamic</CollisionTypeS>
                <!-- BounceStr>0 でプロジェクタイルが跳ねる。ゼロなら PhysicMaterial 無効 -->
                <BounceCombineType>Maximum</BounceCombineType>
                <BounceStr>0.0</BounceStr>
                <FrictionCombineType>Average</FrictionCombineType>
                <FrictionStr>0.0</FrictionStr>
                <!-- カスタム弾頭コライダー: デフォルトのSphereを置き換えるカプセル -->
                <Colliders>
                    <CapsuleCollider>
                        <Position x="0.0" y="0.0" z="0.0" />
                        <Capsule direction="Z" radius="0.06" height="0.35" />
                    </CapsuleCollider>
                </Colliders>
                <Mesh name="100mmShell">
                    <Position x="0.0" y="0.0" z="-0.1" />
                    <Rotation x="0.0" y="-90.0" z="0.0" />
                    <Scale x="0.75" y="0.75" z="0.75" />
                </Mesh>

                <Texture name="metal" />
            </ShootingState>

            <FireKey key="fire" />
            <PowerSlider key="power" />
            <RateOfFireSlider key="rate-of-fire" />

            <ProjectileStart>
                <Position x="0.0" y="-8.5" z="0.5" />
                <Rotation x="90.0" y="0.0" z="0.0" />
                <Scale x="1.0" y="1.0" z="1.0" />
            </ProjectileStart>

            <ShotFlashPosition>
                <Position x="0.0" y="-8.3" z="0.5" />
                <Rotation x="90.0" y="0.0" z="0.0" />
                <Scale x="2.0" y="2.0" z="2.0" />
            </ShotFlashPosition>

            <ProjectilesExplode>false</ProjectilesExplode>
            <ExplodeRadius>5.0</ExplodeRadius>
            <ExplodePower>9000.0</ExplodePower>
            <ExplodeUpPower>-4</ExplodeUpPower>
            <ProjectilesDespawnImmediately>false</ProjectilesDespawnImmediately>

            <!-- タイムフューズ: useTimefuse=true で FuseTimer スライダー値秒後に爆発 -->
            <useTimefuse>true</useTimefuse>
            <FuseTime>3.0</FuseTime>
            <FuseDelayTime>0.0</FuseDelayTime>
            <RandomFuseInterval>0.0</RandomFuseInterval>

            <!-- バーストショット: false で通常、true で BurstShotNum 発連射 -->
            <useBurstShot>false</useBurstShot>
            <RateOfBurst>4.0</RateOfBurst>
            <BurstShotNum>3</BurstShotNum>

            <!-- スポーン遅延 -->
            <useDelay>false</useDelay>
            <DelayTime>1.0</DelayTime>

            <!-- 凍結効果: true にすると命中対象(と子ブロック)を凍結する。凍結非対応ブロックでは無反応 -->
            <useFreezingAttack>false</useFreezingAttack>

            <!-- ブースター: useBooster=trueで発射時に必ずパージ推力が掛かる -->
            <useBooster>false</useBooster>
            <!-- 再着火: useBooster かつ useThrustDelayTimer=true のときのみ、ThrustDelayTimerSlider秒後に同じ推力をもう一度掛ける -->
            <useThrustDelayTimer>false</useThrustDelayTimer>
            <ThrustDelayTimerSlider key="thrust-delay-timer" />
            <PurgeVector x="0.0" y="0.0" z="1.0" />
            <PurgePower>30.0</PurgePower>

            <!-- マガジン/リロード: true で DefaultAmmo を MagazineCapacity 単位の弾倉として管理する -->
            <useMagazine>true</useMagazine>
            <MagazineInfo>
                <useReloadKey>true</useReloadKey>
                <ReloadKey key="reload" />
                <forceAutoReload>true</forceAutoReload>
                <useAutoReloadToggle>false</useAutoReloadToggle>
                <AutoReloadToggle key="auto-reload" />
                <MagazineCapacitySlider key="magazine-capacity" />
                <ReloadTimeSlider key="reload-time" />
                <ReloadSounds>
                    <AudioClip name="reload" />
                </ReloadSounds>
            </MagazineInfo>

            <!-- 物理 -->
            <RecoilMultiplier>0.8</RecoilMultiplier>
            <RandomInterval>0.03</RandomInterval>
            <RandomDiffusion>0.007</RandomDiffusion>

            <!-- エフェクト: バンドル未登録のため空欄。登録後に名前を記入 -->
            <AssetBundleName name="myasset" />
            <ExplodeEffect>APFSDShit</ExplodeEffect>
            <ShotFlashEffect>ShotEffectMB</ShotFlashEffect>
            <TrailEffect>newBulletTrailWV100</TrailEffect>
            <BulletEffect>bulleteffect</BulletEffect>

            <!-- 弾薬: 0 = 無限。非ゼロで上限あり -->
            <DefaultAmmo>20</DefaultAmmo>
            <PoolSize>50</PoolSize>

            <!-- 発射音 / 着弾音: AudioClip 登録後に有効化 -->
            <Sounds>
                <AudioClip name="shot" />
            </Sounds>
            <HitSounds>
                <AudioClip name="hit" />
            </HitSounds>

        </AdShootingProp>
    </Modules>

    <Mesh name="TestCannon">
        <Position x="0.0" y="0.4" z="0.5" />
        <Rotation x="0.0" y="90.0" z="90.0" />
        <Scale x="2.0" y="2.0" z="2.0" />
    </Mesh>
    <Texture name="metal" />

    <Icon>
        <Position x="0.2" y="0.2" z="0.0" />
        <Rotation x="60.0" y="30.0" z="30.0" />
        <Scale x="0.25" y="0.25" z="0.25" />
    </Icon>

    <Colliders>
        <BoxCollider>
            <Position x="0.0" y="0.0" z="0.5" />
            <Rotation x="0.0" y="0.0" z="0.0" />
            <Scale x="0.8" y="0.8" z="0.8" />
        </BoxCollider>
        <CapsuleCollider>
            <Position x="0.0" y="-3.8" z="0.5" />
            <Rotation x="90.0" y="90.0" z="90.0" />
            <Capsule direction="Z" radius="0.24" height="7.5" />
        </CapsuleCollider>
    </Colliders>

    <BasePoint hasAddingPoint="false">
        <Stickiness enabled="true" radius="0.6" />
        <Motion x="false" y="false" z="false" />
    </BasePoint>
</Block>
